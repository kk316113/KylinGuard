# Public browser API base. Leave empty to use Next.js rewrites under /api.
NEXT_PUBLIC_API_BASE_URL=

# Server-side Next.js rewrite target for the Go Agent.
KYLIN_GUARD_AGENT_API_URL=http://127.0.0.1:8080

# CopilotKit provider endpoint placeholder. KylinGuard MVP currently uses
# /api/agent/run-eino directly; AG-UI/Copilot runtime can be wired later.
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit

# Do not put real DeepSeek/OpenAI API keys in frontend env files.
